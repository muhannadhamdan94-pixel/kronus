{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/guides",
      "dest": "/guides/index.html"
    },
    {
      "src": "/guides/(.*)",
      "dest": "/guides/$1.html"
    },
    {
      "src": "/blog",
      "dest": "/guides/index.html"
    },
    {
      "src": "/blog/(.*)",
      "dest": "/guides/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
