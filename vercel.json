{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/blog",
      "destination": "/guides",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/guides/:path*",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/guides",
      "dest": "/guides/index.html"
    },
    {
      "src": "/guides/(.*)",
      "dest": "/guides/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
